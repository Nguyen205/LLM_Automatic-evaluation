    "class LLMSolver:\n",
    "    def __init__(self, ulr=None, api=None, model=None, filename_id=None, token=0, excel_file_path=None):\n",
    "        \"\"\"Initialize OpenAI client with environment variable\"\"\"\n",
    "        self.client = OpenAI(\n",
    "            base_url=ulr,\n",
    "            api_key=api,\n",
    "        )\n",
    "        self.model = model\n",
    "        self.filename_id = filename_id\n",
    "        self.max_token = token\n",
    "        self.excel_file_path = excel_file_path\n",
    "\n",
    "    def setup_drive(self):\n",
    "        \"\"\"In Jupyter: just make sure the folder exists (no Google Drive mount)\"\"\"\n",
    "        try:\n",
    "            excel_file_path = self.excel_file_path\n",
    "            if excel_file_path is None:\n",
    "                raise ValueError(\"excel_file_path is not set\")\n",
    "            os.makedirs(os.path.dirname(excel_file_path), exist_ok=True)\n",
    "            print(f\"AI judgement will be saved to: {excel_file_path}\")\n",
    "        except Exception as e:\n",
    "            print(f\"Error setting up local folder: {e}\")\n",
    "\n",
    "    def load_data(self):\n",
    "        \"\"\"Load Excel file from local path\"\"\"\n",
    "        try:\n",
    "            if self.excel_file_path is None:\n",
    "                raise ValueError(\"No excel_file_path specified\")\n",
    "\n",
    "            df = pd.read_excel(self.excel_file_path)\n",
    "            df = df.dropna(how='all')  # Remove rows where all values are NaN\n",
    "\n",
    "            display(df.iloc[:20, :8])  # Display first 20 rows and 8 columns\n",
    "\n",
    "            total_rows = len(df) / 5\n",
    "            print(f\"Total rows in dataset: {total_rows}\")\n",
    "\n",
    "            return df, total_rows\n",
    "\n",
    "        except Exception as e:\n",
    "            print(f\"Error loading Excel file: {e}\")\n",
    "            return None, 0\n",
    "\n",
    "    def prompt_design(self, mode):\n",
    "        \"\"\"Prompt templates\"\"\"\n",
    "        mode_prompts = {\n",
    "            \"NSD\": \"You will be provided with a conceptual problem. Please solve it using the instructions above.\",\n",
    "            \"IAQ\": \"You are an expert in the Indoor Air Quality Engineering field. You will be provided with a calculation problem. Please solve it using the instructions above.\",\n",
    "            \"AIJ\": \"You are an expert in the Indoor Air Quality Engineering field. You will be given two answers to the same question. Determine whether the two answers convey the same idea or meaning, even if they use different words. Minor differences in wording or grammar can be ignored. If the overall meaning is the same, respond with 1. If the meaning is clearly different, respond with 0. No explanation needed.\"\n",
    "        }\n",
    "        return mode_prompts.get(mode, mode_prompts[\"NSD\"])\n",
    "\n",
    "    def ask_model(self, prompt, mode=None):\n",
    "        \"\"\"Generate response from the AI model\"\"\"\n",
    "        try:\n",
    "            full_prompt = self.prompt_design(mode) + prompt\n",
    "            completion = self.client.chat.completions.create(\n",
    "                extra_headers={\n",
    "                    \"HTTP-Referer\": \"UIUC\",\n",
    "                    \"X-Title\": \"Benchmarking LLM IAQ\",\n",
    "                },\n",
    "                model=self.model,\n",
    "                messages=[{\"role\": \"user\", \"content\": full_prompt}],\n",
    "                max_tokens=self.max_token\n",
    "            )\n",
    "            return completion.choices[0].message.content\n",
    "        except Exception as e:\n",
    "            print(f\"Error in ask_model: {e}\")\n",
    "            return None\n",
    "\n",
    "    def display_Markdown(self, response):\n",
    "        \"\"\"Display the answers in Jupyter\"\"\"\n",
    "        display(Markdown(response))\n",
    "\n",
    "    def update_excel_with_responses(self, response, row_index, excel_path):\n",
    "        \"\"\"Save model response to excel file\"\"\"\n",
    "        try:\n",
    "            df = pd.read_excel(excel_path)\n",
    "\n",
    "            if \"AI judge\" not in df.columns:\n",
    "                df[\"AI judge\"] = \"\"\n",
    "\n",
    "            try:\n",
    "                numeric_response = int(response)\n",
    "            except:\n",
    "                numeric_response = None\n",
    "\n",
    "            if numeric_response is not None:\n",
    "                df.loc[row_index, \"AI judge\"] = numeric_response\n",
    "            else:\n",
    "                df.loc[row_index, \"AI judge\"] = str(response)\n",
    "\n",
    "            df.to_excel(excel_path, index=False)\n",
    "            print(f\"Judgement saved for row {row_index}\")\n",
    "            return True\n",
    "        except Exception as e:\n",
    "            print(f\"Error updating Excel: {e}\")\n",
    "            return None\n",
    "\n",
    "    def process_problems(self, df, batch_size, mode, max_problems, displays_Colab):\n",
    "        \"\"\"Loop through dataset and judge answers\"\"\"\n",
    "        try:\n",
    "            for i_batch in range(1, batch_size + 1):\n",
    "                for index in range(0, 5 * max_problems, 5):\n",
    "                    row_index = index + i_batch - 1\n",
    "                    if row_index >= len(df):\n",
    "                        continue\n",
    "\n",
    "                    try:\n",
    "                        example_id = f\"Row_{row_index}\"\n",
    "                        model_answer = str(df.loc[row_index, \"Model Answer\"]).strip()\n",
    "                        reference_answer = str(df.loc[row_index, \"Reference Answer\"]).strip()\n",
    "\n",
    "                        if not model_answer or not reference_answer:\n",
    "                            print(f\"Skipping {example_id}: Missing answer(s)\")\n",
    "                            continue\n",
    "\n",
    "                        comparison_prompt = f\"\"\"\n",
    "Answer 1: {reference_answer}\n",
    "\n",
    "Answer 2: {model_answer}\n",
    "\"\"\"\n",
    "                        print(f\"Judging alignment for {example_id} in batch {i_batch}\")\n",
    "\n",
    "                        response = self.ask_model(comparison_prompt, mode=\"AIJ\")\n",
    "                        if not response:\n",
