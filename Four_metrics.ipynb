   "source": [
    "import sys\n",
    "!{sys.executable} -m pip install openpyxl\n",
    "\n",
    "# patch setup_drive to skip folder creation\n",
    "def dummy_setup_drive(self):\n",
    "    pass\n",
    "\n",
    "LLMSolver.setup_drive = dummy_setup_drive\n",
    "\n",
    "# then initialize normally\n",
    "solver = LLMSolver(\n",
    "    user_base_url,\n",
    "    user_api_key,\n",
    "    user_model,\n",
    "    user_filename_id,\n",
    "    user_max_token,\n",
    "    excel_file_path=\"SamplingEfficiency_all_output.xlsx\"\n",
    ")\n",
    "\n",
    "solver.setup_drive()  # now does nothing\n",
    "df, total_rows = solver.load_data()\n",
    "\n",
    "\n",
    "run_status = solver.process_problems(\n",
    "    df=df,\n",
    "    batch_size=5,\n",
    "    mode=\"AIJ\",\n",
    "    max_problems=900,\n",
    "    displays_Colab=True,   # works fine in Jupyter too\n",
    ")\n",
    "\n",
    "if run_status:\n",
    "    print(100*\"*\")\n",
    "    print(\"Successfully generated response and saved to Excel.\")"
   ]
  },
